        let currentIndex = 0;
        let score = 0;
        let timeLeft = 0;
        let timerId;
        let answered = false;

        const qText = document.getElementById("question-text");
        const optionsBox = document.getElementById("options-container");
        const actBtn = document.getElementById("action-btn");
        const qCount = document.getElementById("question-counter");
        const timeDisplay = document.getElementById("timer");
        const quizDiv = document.getElementById("quiz-container");
        const resDiv = document.getElementById("result-container");
        const finalScore = document.getElementById("final-score");
        const resMsg = document.getElementById("result-msg");

        function loadQuestion() {
            clearInterval(timerId);
            answered = false;
            actBtn.innerText = "Confirmar Resposta";
            actBtn.disabled = true;

            const qData = db[currentIndex];
            qCount.innerText = `${currentIndex + 1}/${db.length}`;
            qText.innerText = qData[0];
            timeLeft = qData[2];
            updateTimeUI();

            // Mapeando respostas para lembrar qual era a índice 0 (correta)
            let optionsObj = qData[1].map((text, idx) => {
                return { text: text, isCorrect: idx === 0 };
            });

            // Embaralhamento (Shuffle)
            optionsObj.sort(() => Math.random() - 0.5);

            optionsBox.innerHTML = '';
            const labels = ['A', 'B', 'C', 'D', 'E'];

            optionsObj.forEach((opt, index) => {
                const optDiv = document.createElement("div");
                optDiv.className = "option";
                optDiv.innerHTML = `<span class="option-letter">[${labels[index]}]</span> <span>${opt.text}</span>`;
                optDiv.onclick = () => selectOpt(optDiv, opt.isCorrect);
                optionsBox.appendChild(optDiv);
            });

            startTimer();
        }

        let currentSelectionCorrect = false;

        function selectOpt(elem, isCorrect) {
            if(answered) return;
            document.querySelectorAll(".option").forEach(el => el.classList.remove("selected"));
            elem.classList.add("selected");
            currentSelectionCorrect = isCorrect;
            actBtn.disabled = false;
        }

        function startTimer() {
            timerId = setInterval(() => {
                timeLeft--;
                updateTimeUI();
                if(timeLeft <= 0) {
                    clearInterval(timerId);
                    handleTimeout();
                }
            }, 1000);
        }

        function updateTimeUI() {
            const m = Math.floor(timeLeft / 60).toString().padStart(2, '0');
            const s = (timeLeft % 60).toString().padStart(2, '0');
            timeDisplay.innerText = `${m}:${s}`;
            timeDisplay.className = "timer " + (timeLeft > 15 ? "safe" : (timeLeft > 5 ? "warning" : ""));
        }

        function handleTimeout() {
            answered = true;
            actBtn.innerText = "Tempo Esgotado - Avançar";
            actBtn.disabled = false;
            revealAnswers();
        }

        function revealAnswers() {
            document.querySelectorAll(".option").forEach(opt => {
                opt.classList.add("disabled");
                // Achando a correta pelo banco de dados original daquela questão (A string exata de índice 0)
                if(opt.innerText.includes(db[currentIndex][1][0])) {
                    opt.classList.add("correct");
                }
            });
        }

        actBtn.onclick = () => {
            if(!answered) {
                // Checar resposta escolhida
                clearInterval(timerId);
                answered = true;
                
                const selected = document.querySelector(".option.selected");
                revealAnswers();

                if(currentSelectionCorrect) {
                    score++;
                } else {
                    selected.classList.add("wrong");
                }

                actBtn.innerText = "Próxima Pergunta >>";
            } else {
                // Avançar tela
                currentIndex++;
                if(currentIndex < db.length) {
                    loadQuestion();
                } else {
                    showResults();
                }
            }
        };

        function showResults() {
            quizDiv.style.display = "none";
            resDiv.style.display = "block";
            const p = Math.round((score / db.length) * 100);
            finalScore.innerText = `${p}%`;
            if(p >= 80) {
                finalScore.classList.add("pass");
                resMsg.innerText = "Aprovado! Você atingiu o domínio dos pré-requisitos L1 a L4.";
            } else {
                finalScore.classList.add("fail");
                resMsg.innerText = "Reprovado. Necessário revisar o Guia de Estudo Dirigido antes da aula presencial.";
            }
        }

        // Boot
        loadQuestion();
    </script>
